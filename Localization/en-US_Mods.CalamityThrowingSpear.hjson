			[c/aa5fff:Keep your distance; let your will reign over desire and instinct.]
			[c/aa5fff:Only then, when the requiem plays, can you command celestial bodies and stir the galaxy.]
			'''
	}

	XiaoZhiTiaoFT: {
		DisplayName: Dragon Nirvana
		Tooltip:
			'''
			[c/ffa500: Dragon Nirvana], the omen of [c/ffa500: victory flame will burn your body]
			If you survive this [c/ffa500: victory flame], then I will become your right-hand man
			But as a price, I will chatter in your ears all the time
			But I am kind-hearted, I can't bear to see others suffer
			So when others suffer, [c/ffa500: victory flame] will quickly end their lives
			So they won't suffer [c/ffa500::)]
			And if you think I'm noisy, you can deprive me of my right to speak in the configuration [c/d3d3d3: configuration settings]
			I can't stop you [c/ffa500::(]
			'''
	}

	XiaoZhiTiaoLL: {
		DisplayName: An execution without witnesses
		Tooltip:
			'''
			[c/ADD8E6: The hunter never fell in to obtain answers.]
			[c/ADD8E6: The knight never jumped up and rushed to the We Many.]
			[c/ADD8E6: The short-lived friendship did not exist.]
			[c/ADD8E6: It was just that the hunter's anchor hit the knight's warhorse.]
			[c/ADD8E6: The favor of fate lost contact again.]
			'''
	}

	XiaoZhiTiaoRE: {
		DisplayName: Revelation - Part I
		Tooltip:
			'''
			[c/494949:"The fate of steel is destruction, yet from destruction arises truth."]
			[c/494949:"Now, cast away those two obsidian relics that were never yours,]
			[c/494949:and let the world grant you a new revelation."]
			'''
	}

	KaiJuXiaoZhiTiao: {
		DisplayName: An instruction manual?
		Tooltip:
			'''
			This mod contains all the throwing versions of the pike in CalamityMod. 
			Please go to Settings > Control Buttons > Configure Custom Buttons > Switch Spear. 
			Press the key while holding a spear to switch to the corresponding version of the javelin, and vice versa
			'''
		ShiftTip: Hold Left Shift to view more details.
		ShiftTipDetailed:
			'''
			Thanks to the following individuals for their contributions to the mod [in no particular order]:
			Southern Kite、锯角、VectorChaos、终末犽戎、Homo Computer、Yukimu、Endticle Star
			'''
	}

	XiaoZhiTiaoLL2: {
		DisplayName: An execution without witnesses
		Tooltip: Challenge:slay a Seahorse with an Anchor for the first time
	}

	XiaoZhiTiaoSG2: {
		DisplayName: Sagittarius
		Tooltip: Challenge:defeat the Empress of Light with 4 or fewer hits
	}

	XiaoZhiTiaoTM2: {
