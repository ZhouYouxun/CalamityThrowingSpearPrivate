		Tooltip: Challenge:make Yharon enter the Phase 2
	}

	XiaoZhiTiaoRE2: {
		DisplayName: Revelation - Part I
		Tooltip: Challenge:throw Ultima and Starmada as an item in the same time
	}

	XiaoZhiTiaoEA2: {
		DisplayName: Proverb of Starnight
		Tooltip: Challenge:defeat Moon Lord without consuming any of the Calamity Permanent Health Upgrades items
	}

	XiaoZhiTiaoSoD: {
		DisplayName: A Wondrous Journey
		Tooltip:
			'''
			[c/e1ffff:“O soul of darkness, accept this absurd masquerade.”]
			[c/e1ffff:“Bring an unflinching end to sorrow.”]
			[c/e1ffff:“Bury the promise deep within the memories of the comet-born.”]
			[c/e1ffff:“Offer the pocket watch that bridges past and present.”]
			[c/e1ffff:“Like a falling jewel, washed free of all pretense.”]
			[c/e1ffff:“A tale of stars, drifting from the unknowable beyond.”]
			'''
	}

	XiaoZhiTiaoSoD2: {
		DisplayName: A Wondrous Journey
