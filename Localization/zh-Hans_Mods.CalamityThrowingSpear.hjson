			Tooltip:
				'''
				击中敌人后往左右各释放六发无限穿透的冷却电池并积攒电量
				冷却电池在初始的12帧内不造成伤害
				右键消耗电量发射一个高速追踪弹射球状闪电
				[c/fff994:“到底是那个天才想到把电池插在棍子上当武器的]
				[c/fff994:“我要用这玩意让他的脑袋好好‘冷却’一下”]
				'''
		}

		FinishingTouch: {
			DisplayName: 画龙点睛
			Tooltip:
				'''
				左键丢出长枪，命中后沿着速度方向依次释放数个冲击波，造成多次伤害
				每扔出九根长枪，第十根长枪便会被强化
				强化长枪在飞行一段距离后会化作巨龙升入天空，随后猛然落下
				右键以持续消耗自身许多生命值为代价，举起长枪
				在一定的蓄力时间过后往鼠标位置处持续发动冲刺
				冲刺期间释放数圈火球，撞击敌人时造成巨额伤害
				[c/ff7335:“吾名为……希腊奶！我堂希腊奶！用此枪，终结这……荒唐而又幼稚的梦！”]
				'''
		}

		MiracleMatterJav: {
			DisplayName: 恒辉之矛
			Tooltip:
				'''
				扎入敌人体内，持续造成伤害
				并在弹幕消失时爆发出多枚追踪能量弹
				[c/757575:“比起隔壁，它有点轻”]
				'''
		}

		SawBladeForkHornJav: {
			DisplayName: 锯刃叉角枪
			Tooltip:
				'''
				握在手里蓄力三秒并将其扔出
				飞行过程中无限穿透且无视无敌帧
				击中敌人时粉碎他们的防御力与伤害减免
				每次击中敌人都会给予玩家可堆叠的防御力与伤害减免
				右键消耗给玩家的可堆叠增益
				同时丢出武器悬停在空中并进行额外的辅助攻击
				[c/645c02:“最简单的逻辑，最粗暴的效果”]
				'''
		}

		ShadowJav: {
			DisplayName: E̸̬͖̋̈́R̷͉̐R̷̢̿͝O̴̮̯͗͑R̶̳̀̋
			Tooltip:
				'''
				左键扔出长枪
				飞行一小段距离后在原地分列出2~4发随机长枪
				仅包含本模组的长枪弹幕，不包含开发者武器
				分裂长枪时无视该长枪的限制
				自身在分裂之后继续飞行并无限穿透
				右键射出可以追踪并粘附在敌人身上的长枪
				粘附过程中可以不断的从周围召唤随机长枪
				右键长枪的存在期间点击左键或右键将会清除它并重新释放
				[c/8f8f8f:“无视风险，继续安装”]
				'''
		}

		TheOtherMiracleMatterJav: {
			DisplayName: 视界探针
			Tooltip:
				'''
				丢出缓慢的长枪，命中时产生爆炸同时从上方召唤多条激光与火焰
				飞行一段时间后还未击中敌人则会往玩家处回收
				回收阶段可以无限穿透
				[c/757575:“比起隔壁，有亿点重”]
				'''
		}

		Revelation: {
			DisplayName: 启示录
			Tooltip:
				'''
				长按左键将启示录握在手中，一秒之后松开左键将其丢出
				握持时间少于一秒会降低一定程度的伤害，时间越短降伤越严重
				点击鼠标右键可以手动摧毁存在的启示录
				每命中敌人5次会使武器的强化提升一个等级，初始等级为零级
				零级--命中后发生小范围爆炸
				一级--伤害、速度与爆炸范围获得小幅提升
				二级--自身高度发光，伤害大幅提升，飞行过程中伴随着追踪光矢
				三级--进一步提升伤害，更换爆炸形态，爆炸会造成元素谐鸣
				四级--进一步提升速度，爆炸时产生大量可以追踪敌人的彗星
				受到伤害或者未击中任何物体时降低一个等级
				不再持有该武器时将等级清空，再次切换回来不会恢复等级
				[c/494949:“凝结了人类文明的所有科技，外行人估计是无法理解这些的”]
				'''
		}

		SoulSeekerJav: {
			DisplayName: 终幕残翼
			Tooltip:
				'''
				命中敌人时开始螺旋飞行，并持续释放火焰弹
				每次命中敌人都会获得一只至尊探魂眼
				至尊探魂眼会盘旋着玩家
				能够造成接触伤害的同时跟随武器本体攻击而进行协同攻击
				点击右键命令他们全部冲刺过去，施加一秒钟的孱弱巫咒
				至尊探魂眼最多存在10只，如果数量为满那么本体击中敌人造成更高的伤害
				使用镀金鸟喙进行死灵灌注即可获取，丢进微光中转化回镀金鸟喙
				[c/630000:“巨龙是喑哑的螺旋，自世界破碎的灵魂中汲取力量，徒长，直至落幕”]
				'''
		}

		TheOtherRevelation: {
			// Tooltip: ""
			// DisplayName: The Other Revelation
		}

		PrimordialState: {
			DisplayName: 无极
			Tooltip:
				'''
				在飞行一段时间后开始追踪
				追踪期间每隔12帧产生一个阴阳鱼
				阴阳鱼会持续追踪长矛并造成高频的伤害
				长矛追踪一段时间后会向着随机方向飞出
				飞出时同时生成数个阴阳玉
				阴阳玉会在击中时弹射并产生阴阳爆炸
				[c/e1ffff:“将这澄澈的天空以思绪遮盖。我愿献上此身，令血悉数洒落大地。”]
				[c/2f2f2f:“此般污秽之躯已无可供升入之天空……所有的邪秽之物啊！与我一同停驻至永恒吧！”]
				'''
		}

		StarsofDestiny: {
			Tooltip:
				'''
				左键扔出长针枪，到底特定位置后散射流星
				右键扔出短针枪，扎在目标上形成立场，可被长针枪提前引爆
				长按左键可蓄力提升长针枪的伤害，造成伤害后短暂提升机动性
				[c/FFFFFF:“海洋与冰雪之国的女王把你误认为自己的爱人”]
				'''
			DisplayName: 命定星启
		}

		AuricSpear: {
			// DisplayName: Auric Spear
			// Tooltip: ""
		}
	}
}

Items: {
	XiaoZhiTiaoSG: {
		DisplayName: 人马座
		Tooltip:
			'''
			[c/fff94b:没有人会觉得这是一场公平的战争]
			[c/fff94b:对她和对你而言都是如此]
			[c/fff94b:应该已经听闻了原始之光的恐怖实力]
			[c/fff94b:因此你要做的便是在保证存活的情况之下，尽可能维持健康状态]
			[c/fff94b:根据相关文献，以前的战斗过程中几乎没有人能挺过第4下]
			[c/fff94b:因此我对你也有相同的要求]
			[c/fff94b:你需要为了这份奖励继续努力一下]
			'''
	}

	XiaoZhiTiaoTM: {
		DisplayName: 某一篇古生物海洋学研究论文
		Tooltip:
			'''
			[c/689bf4:从这个世界出现以来，一直围绕着海洋生物就有无数的传说]
			[c/689bf4:因其躲过数次大灾难，有人歌颂其顽强的生命力]
			[c/689bf4:亦或是经过合理驯服之后，可以与人类保持着极好的友好程度]
			[c/689bf4:无论是哪一种都无不提醒着人类对于海洋的未知]
			[c/689bf4:虽然能被称作顶级掠食者，但他们很难拥有真正的神力]
			[c/689bf4:并不是所有的宝物都能够每次出现，有些东西需要在你足够快才愿意出现]
			[c/689bf4:现在请尝试再快一点完成这场战斗，如果时机允许，他将现身]
			'''
	}

	XiaoZhiTiaoEA: {
		DisplayName: 星夜箴言
		Tooltip:
			'''
			[c/aa5fff:宇宙辐射于四色生命结晶中汇聚]
			[c/aa5fff:使人心灵受染，结构扭曲]
			[c/aa5fff:远离它们，保持意志凌驾于欲望和本能之上]
			[c/aa5fff:方可在安魂曲奏响之时，驭使天体，挑动银河]
			'''
	}

	XiaoZhiTiaoFT: {
		DisplayName: 巨龙涅槃
		Tooltip:
			'''
			[c/ffa500:巨龙涅槃]之时，象征[c/ffa500:胜利的火焰将会焚烧你的躯体]
			如果你在这[c/ffa500:胜利的火焰]中存活下来，那么我将成为你的得力干将
			但作为代价，我会无时无刻地在你耳边喋喋不休
			不过我这人心善，我不忍心看到其他人痛苦
			所以其他人痛苦时，[c/ffa500:胜利的火焰]将会迅速地结束他们的生命
			这样他们就不会痛苦了[c/ffa500::)]
			而如果你觉得我吵的话，你可以在配置[c/d3d3d3:配置设置]里剥夺我的发言权
			我也阻止不了你[c/ffa500::(]
			'''
	}

	XiaoZhiTiaoLL: {
		DisplayName: 一场没有人见证的处决
		Tooltip:
			'''
			[c/ADD8E6:猎人不曾以堕落换取答案]
			[c/ADD8E6:骑士不曾一跃起冲赴大群]
			[c/ADD8E6:短暂的友谊亦不存在]
			[c/ADD8E6:只是猎人的锚重击在骑士的战骑]
			[c/ADD8E6:命运的眷顾再次失联]
			'''
	}

	XiaoZhiTiaoRE: {
		DisplayName: 启示录-前篇
		Tooltip:
			'''
			[c/494949:“钢铁的终点是毁灭，但在毁灭中诞生真知。]
			[c/494949:现在，抛下那两份极黑色的，不属于你的旧力，让世界重新赋予你启示。”]
			'''
	}

	KaiJuXiaoZhiTiao: {
		DisplayName: 一张说明书？
		Tooltip:
			'''
			本模组内含所有原灾长枪的投掷版本
			请前往设置》控制按键》配置自定义按键》更改长枪形态
			手持戳刺长枪按下切换键可以切换至对应版本的投掷长枪，反之亦然
			'''
		ShiftTip: 按住左Shift键查看更多详细信息
		ShiftTipDetailed:
			'''
			感谢以下人员对mod作出的贡献【排名不分先后】
			南鸢北笙、锯角、VectorChaos、终末犽戎、家庭电脑、沐雪凝春Yukimu、终子星Endticle Star
			'''
	}

	XiaoZhiTiaoLL2: {
		DisplayName: 一场没有人见证的处决
		Tooltip: 挑战：用锚杀死海马
	}

	XiaoZhiTiaoSG2: {
		DisplayName: 人马座
		Tooltip: 挑战：受击数小于等于4的情况下击败光之女皇
	}

	XiaoZhiTiaoTM2: {
		DisplayName: 某一篇古生物海洋学研究论文
		Tooltip: 挑战：在两分钟之内击杀猪龙鱼公爵
	}

	XiaoZhiTiaoFT2: {
		DisplayName: 巨龙涅槃
		Tooltip: 挑战：使犽戎进入二阶段
	}

	XiaoZhiTiaoRE2: {
		DisplayName: 启示录-前篇
		Tooltip: 挑战：扔出创世纪和群星大炮，使它们同时处于掉落物状态
	}

	XiaoZhiTiaoEA2: {
		DisplayName: 星夜箴言
		Tooltip: 挑战：在不吃下任何一种灾厄水果的情况下击杀月球领主
	}

