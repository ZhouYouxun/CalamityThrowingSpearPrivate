	EAfterDog: {
		AuricJav: {
			DisplayName: 金源量子带电调试棒
			Tooltip:
				'''
				击中敌人后往左右各释放六发无限穿透的冷却电池
				冷却电池在初始的12帧内不造成伤害
				[c/fff994:“到底是那个天才想到把电池插在棍子上当武器的]
				[c/fff994:“我要用这玩意让他的脑袋好好‘冷却’一下”]
				'''
