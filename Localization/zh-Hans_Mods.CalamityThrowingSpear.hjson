				[c/2836a1:“永恒的狩猎...开始了...”]
				'''
			Tooltip: "[GFB]"
			TooltipGFB: 师爷，屁股在树上呢，不疼了”
		}

		TerraLance: {
			DisplayName: 古茂垠峰
			Tooltip:
				'''
				击中敌人之后释放泰拉爆炸
				并从周围召唤数条无限穿透的泰拉激光
				[c/89ff69:“它配了，终于”]
				'''
