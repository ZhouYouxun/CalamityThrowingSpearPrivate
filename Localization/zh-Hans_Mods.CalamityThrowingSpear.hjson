ChangedWeapons: {
	APreHardMode: {
		AmidiasTridentJav: {
			DisplayName: 海王三叉戟
			Tooltip:
				'''
				丢出能够扎在敌人身上或者物块上的三叉戟
				三叉戟消失时释放水柱或闪电
				右键呼叫三叉戟进行回收，回收期间无限穿透
				回到玩家时能够释放几个追踪水龙卷
				[c/5276fc:“你是想要水呢、还是想要电呢”]
				'''
		}

		GoldplumeJav: {
			DisplayName: 金羽
			Tooltip:
				'''
				手持时释放一个跟随鼠标的旋风
				长矛能够穿透2次并在命中时朝着后方两个固定角度释放两根羽毛
				长矛命中旋风时会被旋风吸住，在一段时间后或碰撞时释放数个羽毛
				羽毛受重力影响且不能穿过物块也不能穿透敌怪
				[c/52f2fc:“天羽屠髅武”]
				'''
		}

		SausageMakerJav: {
			DisplayName: 香肠矛
			Tooltip:
				'''
				可以穿透多次
				消失时释放追踪血弹
				[c/a21c12:“好次”]
				'''
		}

		YateveoBloomJav: {
			DisplayName: 绽花毒藤
			Tooltip:
				'''
				在方块上反弹，向最近的敌人释放致命叶子
				右键丢出无限穿透的毒藤长枪
				[c/34a212:“赠人玫瑰，手有余猩”]
				'''
		}
	}

	BPrePlantera: {
		BrimlanceJav: {
			DisplayName: 硫磺火矛
			Tooltip:
				'''
				击中敌人后再飞行一段距离产生一个硫磺火环
				硫磺火环会伤害接触到它的敌怪并向外喷射硫磺火
				[c/a21512:“啊↑哈↓黑圈！”]
				'''
		}

		EarthenJav: {
			DisplayName: 磐石地元叉
			Tooltip:
				'''
				命中物块时粘在上面
				然后往前方召唤多个会飞起来的岩石碎片
				[c/ac8f50:“地道战”]
				'''
		}

		StarnightLanceJav: {
			DisplayName: 星夜长枪
			Tooltip:
				'''
				本体追踪，消失时释放转向追踪的星夜光束
				[c/f692ff:“极光效应”]
				'''
		}
	}

	CPreMoodLord: {
		AstralPikeJav: {
			DisplayName: 幻星矛
			Tooltip:
				'''
				击中敌人时，投矛会产生星爆并在远端召唤幻星
				如果撞击物块，那么投矛会穿墙并追踪敌人
				[c/ffbf73:“钻地流星”]
				'''
		}

		BotanicPiercerJav: {
			DisplayName: 翠芒尖枪
			Tooltip:
				'''
				飞行很短的时间后快速分裂成两发追踪植物能量束
				分裂前投矛本体造成150%伤害
				[c/8dff73:“不，你不想用它直接命中敌人”]
				'''
		}

		DiseasedJav: {
			DisplayName: 瘟疫长枪
			Tooltip:
				'''
				扔出三根具备追踪能力的长矛，长矛在攻击到敌人时会被弹开
				第二次命中时释放瘟疫环与三个追踪的瘟疫弹
				[c/49ff1f:“传播的疾病中不包含猪瘟”]
				'''
		}

		GalvanizingGlaiveJav: {
			DisplayName: 磁能分割刀
			Tooltip:
				'''
				击中敌人时释放多个能量弹
				或者原地旋转的磁能漩涡
				[c/1ffbff:“左零右火，雷公助我”]
				'''
		}

		HellionFlowerJav: {
			DisplayName: 刺花长矛
			Tooltip:
				'''
				无限穿透，飞行期间往两边不断的发射花瓣并在周边生成几个紧随长矛的种子
				种子带有隐形的伤害光环，而长矛会逐渐减速
				速度归零时会释放毒气与6根荆棘
				[c/007708:“春暖花开，众生皆亡”]
				'''
		}

		TenebreusTidesJav: {
			DisplayName: 深渊潮涌
			Tooltip:
				'''
				蓄力期间持续在鼠标周围生成小型三叉戟瞄准鼠标位置
				松手时扔出本体，飞行过程中产生更多的小三叉戟
				[c/001087:“是的，我可以证明，波塞冬就是从我这里进的货”]
				'''
		}

		TyphonsGreedJav: {
			DisplayName: 提丰之贪婪
			Tooltip:
				'''
				撞墙或是飞行一段时间后立刻释放一圈水球并进入旋转攻击模式
				旋转模式期间不断的向外释放可以追踪的水弹
				[c/2f366b:“提丰没有心，但它有胃”]
				'''
		}

		VulcaniteLanceJav: {
			DisplayName: 火山之矛
			Tooltip:
				'''
				扔出一根受重力的长矛
				一段时间后喷发出三个能追踪的火焰球
				本体命中物块或至少两个敌怪后造成巨大面积的持续性火焰
				[c/ff8400:“1200°C的玄武岩碎片”]
				'''
		}
	}

	DPreDog: {
		BansheeHookJav: {
			DisplayName: 女妖之爪
			Tooltip:
				'''
				直线飞行，撞到敌人后弹开
				随后会重新飞回这个敌人，第2次造成更高伤害
				消失时释放三片镰刀，随后镰刀会开始往玩家处回收
				[c/ffbcd5:“上面不都写了吗，这是可回收物”]
				'''
		}

		ElementalLanceJav: {
			DisplayName: 元素长枪
			Tooltip:
				'''
				按照顺序丢出五种矛
				日耀投矛命中后会持续追踪攻击目标4次
				星璇投矛命中后会在目标头顶生成漩涡，漩涡会在几秒后向下释放闪电和导弹
				星云投矛命中后会产生数条星云射线
				星尘投矛会粘在目标身上持续造成伤害并在消失时生成4个星星
				冥思投矛命中后会在接下来的几秒后造成巨大爆炸
				[c/8e8e8e:“最应该出现的白矮星却没有到场”]
				'''
		}

		GildedProboscisJav: {
			DisplayName: 镀金鸟喙
			GFBName: 癫痫屮
			Tooltip:
				'''
				击中敌人时释放静电光球回到玩家身边随后产生一只癫狂龙裔
				癫狂龙裔最多存在21只，如数量为满则提升长枪本体伤害
				每一只的伤害会随着总数量的提升而变多
				点击右键将它们全部发射出去
				即使切换武器也不会导致癫狂龙裔消失
				[c/ffc71d:“爱鸟人士表示强烈谴责”]
				'''
		}
	}

	EAfterDog: {
		DragonRageJav: {
			DisplayName: 巨龙之怒
			Tooltip:
				'''
				手持时将不断旋转巨龙之怒轰炸接触到的敌怪
				按住左键允许巨龙之怒在无限范围内追踪鼠标，但距离越远伤害越低
				右键将旋转巨龙之怒并在周边持续生成光球，光球高速旋转一段时间后冲向鼠标位置
				左键的优先级高于右键
				[c/ffc27a:“它要转到什么时候”]
				'''
		}

		NadirJav: {
			DisplayName: 天底
			Tooltip:
				'''
				飞行过程中和命中时都可以生成飞升的深渊精华
				深渊精华能够追踪敌怪并在命中时释放数个虚空触手
				[c/867891:“它从哪里飞出来的”]
				'''
		}

		ScourgeoftheCosmosJav: {
			DisplayName: 灾劫宙怨
			Tooltip:
				'''
				手持时随机在周边落下苹果，长矛击中苹果时会获得追踪能力并为你回复2点生命
				命中时释放数个只能直角拐弯的追踪型小吞噬者
				[c/9d5ad0:“我是贪吃蛇，喜欢吃苹果，越吃越厉害”]
				'''
		}

		StreamGougeJav: {
			DisplayName: 宇宙暗流
			Tooltip:
				'''
				扔出一根高速移动的长矛，在路径上持续产生长矛幻影伤害接触到的敌怪
				长矛在穿透7次或飞行一小段时间后在原地爆炸
				爆炸后会在周边5个敌人身上释放一个长矛幻影对其进行一次挥砍
				[c/9d5ad0:“神秘七费艺术书页”]
				'''
		}

		ViolenceJav: {
			DisplayName: 恣睢
			Tooltip:
				'''
				每次击中敌人都会从玩家处释放多个追踪硫火弹
				默认释放2发，场上每存活一个敌方Boss单位便会增加一发
				蠕虫类Boss仅算一个
				[c/a50101:“你们一起上吧，我等不及了”]
				'''
		}
	}
}

