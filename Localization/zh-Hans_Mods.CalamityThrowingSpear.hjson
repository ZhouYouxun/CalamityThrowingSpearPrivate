ModBuff: {
	SagittariusEDebuff: {
		DisplayName: 人马座耀光
		Description:
			'''
			在白天降低30%的攻击力，在晚上降低50%的防御力
			无论白天还是黑夜，这对于敌人来说都不是什么好事
			'''
	}

	CreateVictoryPEBuff: {
		DisplayName: 创造胜利
		Description: 损失大量的生命值与防御力
	}

	SawBladeForkHornEDebuff: {
		DisplayName: 粉碎性骨折
		Description:
			'''
			就像名字一样
			粉碎性骨折
			'''
	}

	SawBladeForkHornPBuff: {
		DisplayName: 防御膨胀学说
		Description:
			'''
			可堆叠的防御力！
			惊不惊喜？意不意外？
			'''
	}

	TheLastLancePBuff: {
		DisplayName: 冲锋形态
		Description:
			'''
			其过往在陆地上逝去，当下与未来亦无意义。
			唯有海洋，杀死海洋。			
			'''
	}
}

Configs: {
	CTSConfigs: {
		DisplayName: CTS Configs

		EnableFTSound: {
			Label: 开启部分武器的自定义语音
			Tooltip:
				'''
				当前版本所有具有语音的武器：
				画龙点睛
				'''
		}

		EnableMeleeSpeed: {
			Label: 禁用全局近战攻速加成（需要重新加载）
			Tooltip:
				'''
				开启此选项后，将使本模组所有武器不受攻速加成影响
				反之亦然
				'''
		}

		EnableRogue: {
			Label: 启用盗贼
			Tooltip:
				'''
				将所有武器和弹幕的职业类型改为盗贼
				注：开启后不会获得全新的潜伏攻击
				'''
		}
	}
}

