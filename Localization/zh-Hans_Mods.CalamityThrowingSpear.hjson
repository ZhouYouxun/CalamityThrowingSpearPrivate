				[c/ffd700:第五下同时丢出刀片和残片，在终点处返回并产生大撕裂]
				[c/ffa500:右键献祭大量生命值对现实进行多次切割]
				经过了某人的改造，天赐之物展现出了更强大的力量
				但同时，使用者也需付出一定的代价
				[c/ff0000:如果有食用过4种提升最大生命值的物品]
				[c/ff0000:献祭生命值时会付出更严重的代价]
				[c/aa5fff:“世间万物皆有其价，无人能够幸免于难”]
				'''
		}

		EndlessDevourJav: {
			DisplayName: 无止之噬
			Tooltip:
				'''
				击中敌人时从远方产生三发追踪的虚空
				与此同时将一定范围内的敌方弹幕转化为我方弹幕重新释放
				转化后的弹幕将具备原先伤害的6倍
				[c/320055:“你知道镜子的工作原理吗，这把武器跟镜子可以说是一点关系都没有”]
				'''
		}

		InfiniteDarknessJav: {
			DisplayName: 无边黑暗
			Tooltip:
				'''
				极快的速度消失，随后出现在敌人旁边并刺向他
				如果在消失前击中敌人则造成更高的伤害
				[c/492861:“避无可避，防不胜防”]
				'''
		}

		SoulHunterJav: {
			DisplayName: 魂狩
			TooltipNormal:
				'''
