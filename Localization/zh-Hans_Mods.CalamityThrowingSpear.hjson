		FinishingTouch: {
			DisplayName: 画龙点睛
			Tooltip:
				'''
				左键直接丢出长枪，飞行一段距离后爆炸并释放大量追踪火球
				右键以持续消耗自身许多生命值为代价，举起长枪
				在一定的蓄力时间过后往鼠标位置处持续发动冲刺
				冲刺期间释放数圈火球，撞击敌人时造成巨额伤害
				[c/ff7335:“红色的羁绊圆圈开始扩展之时，真相与精神便会传递给大家”]
				'''
		}

		MiracleMatterJav: {
			DisplayName: 恒辉之矛
			Tooltip:
				'''
				扎入敌人体内，持续造成伤害
				并在弹幕消失时爆发出多枚追踪能量弹
				[c/757575:“比起隔壁，它有点轻”]
				'''
		}

		SawBladeForkHornJav: {
			DisplayName: 锯刃叉角枪
			Tooltip:
				'''
				握在手里蓄力三秒并将其扔出
				飞行过程中无限穿透且无视无敌帧
				击中敌人时粉碎他们的防御力与伤害减免
				每次击中敌人都会给予玩家可堆叠的防御力与伤害减免
				右键消耗给玩家的可堆叠增益
				同时丢出武器悬停在空中并进行额外的辅助攻击
				[c/645c02:“最简单的逻辑，最粗暴的效果”]
				'''
		}

		ShadowJav: {
			DisplayName: 无极
			Tooltip:
				'''
				左键扔出长枪
				飞行一小段距离后在原地分列出2~4发随机长枪
				仅包含本模组的长枪弹幕，不包含开发者武器
				分裂长枪时无视该长枪的限制
				自身在分裂之后继续飞行并无限穿透
				右键射出可以追踪并粘附在敌人身上的长枪
				粘附过程中可以不断的从周围召唤随机长枪
				右键长枪的存在期间点击左键或右键将会清除它并重新释放
				[c/8f8f8f:“包罗万象，道合乾坤”]
				'''
		}

		TheOtherMiracleMatterJav: {
			DisplayName: 视界探针
			Tooltip:
				'''
				丢出缓慢的长枪，命中时产生爆炸同时从上方召唤多条激光与火焰
				飞行一段时间后还未击中敌人则会往玩家处回收
				回收阶段可以无限穿透
				[c/757575:“比起隔壁，有亿点重”]
				'''
		}

		Revelation: {
			DisplayName: 启示录
			Tooltip:
				'''
				长按左键将启示录握在手中，一秒之后松开左键将其丢出
				握持时间少于一秒会降低一定程度的伤害，时间越短降伤越严重
				点击鼠标右键可以手动摧毁存在的启示录
				每命中敌人5次会使武器的强化提升一个等级，初始等级为零级
				零级--命中后发生小范围爆炸
				一级--伤害、速度与爆炸范围获得小幅提升
				二级--自身高度发光，伤害大幅提升，飞行过程中伴随着追踪光矢
				三级--进一步提升伤害，更换爆炸形态，爆炸会造成元素谐鸣
				四级--进一步提升速度，爆炸时产生大量可以追踪敌人的彗星
				受到伤害或者未击中任何物体时降低一个等级
				不再持有该武器时将等级清空，再次切换回来不会恢复等级
				[c/494949:“凝结了人类文明的所有科技，外行人估计是无法理解这些的”]
				'''
		}

		SoulSeekerJav: {
			DisplayName: 终幕残翼
			Tooltip:
				'''
				飞行一段时间或击中方块后获得追踪能力
				每次命中敌人都会获得一只至尊探魂眼
				至尊探魂眼会盘旋着玩家不造成伤害
				点击右键命令他们全部冲刺过去，施加一秒钟的孱弱巫咒
				至尊探魂眼最多存在10只，如果数量为满那么本体击中敌人造成更高的伤害
				使用镀金鸟喙进行死灵灌注即可获取，丢进微光中转化回镀金鸟喙
				[c/630000:“巨龙是喑哑的螺旋，自世界破碎的灵魂中汲取力量，徒长，直至落幕”]
				'''
		}

		TheOtherRevelation: {
			// Tooltip: ""
			// DisplayName: The Other Revelation
		}

		PrimordialState: {
			// DisplayName: Primordial State
			// Tooltip: ""
		}

		StarsofDestiny: {
			// Tooltip: ""
			// DisplayName: Starsof Destiny
		}
	}
}

Items: {
	XiaoZhiTiaoSG: {
		DisplayName: 人马座
		Tooltip:
			'''
			[c/fff94b:没有人会觉得这是一场公平的战争]
			[c/fff94b:对她和对你而言都是如此]
			[c/fff94b:应该已经听闻了原始之光的恐怖实力]
			[c/fff94b:因此你要做的便是在保证存活的情况之下，尽可能维持健康状态]
			[c/fff94b:根据相关文献，以前的战斗过程中几乎没有人能挺过第4下]
			[c/fff94b:因此我对你也有相同的要求]
			[c/fff94b:你需要为了这份奖励继续努力一下]
			'''
	}

	XiaoZhiTiaoTM: {
		DisplayName: 某一篇古生物海洋学研究论文
		Tooltip:
			'''
			[c/689bf4:从这个世界出现以来，一直围绕着海洋生物就有无数的传说]
			[c/689bf4:因其躲过数次大灾难，有人歌颂其顽强的生命力]
			[c/689bf4:亦或是经过合理驯服之后，可以与人类保持着极好的友好程度]
			[c/689bf4:无论是哪一种都无不提醒着人类对于海洋的未知]
			[c/689bf4:虽然能被称作顶级掠食者，但他们很难拥有真正的神力]
			[c/689bf4:并不是所有的宝物都能够每次出现，有些东西需要在你足够快才愿意出现]
			[c/689bf4:现在请尝试再快一点完成这场战斗，如果时机允许，他将现身]
			'''
	}

	XiaoZhiTiaoEA: {
		DisplayName: 星夜箴言
		Tooltip:
			'''
			[c/aa5fff:宇宙辐射于四色生命结晶中汇聚]
			[c/aa5fff:使人心灵受染，结构扭曲]
			[c/aa5fff:远离它们，保持意志凌驾于欲望和本能之上]
			[c/aa5fff:方可在安魂曲奏响之时，驭使天体，挑动银河]
			'''
	}

	XiaoZhiTiaoFT: {
		DisplayName: 巨龙涅槃
		Tooltip:
			'''
			[c/ffa500:巨龙涅槃]之时，象征[c/ffa500:胜利的火焰将会焚烧你的躯体]
			如果你在这[c/ffa500:胜利的火焰]中存活下来，那么我将成为你的得力干将
			但作为代价，我会无时无刻地在你耳边喋喋不休
			不过我这人心善，我不忍心看到其他人痛苦
			所以其他人痛苦时，[c/ffa500:胜利的火焰]将会迅速地结束他们的生命
			这样他们就不会痛苦了[c/ffa500::)]
			而如果你觉得我吵的话，你可以在配置[c/d3d3d3:配置设置]里剥夺我的发言权
			我也阻止不了你[c/ffa500::(]
			'''
	}

	XiaoZhiTiaoLL: {
		DisplayName: 一场没有人见证的处决
		Tooltip:
			'''
			[c/ADD8E6:猎人不曾以堕落换取答案]
			[c/ADD8E6:骑士不曾一跃起冲赴大群]
			[c/ADD8E6:短暂的友谊亦不存在]
			[c/ADD8E6:只是猎人的锚重击在骑士的战骑]
			[c/ADD8E6:命运的眷顾再次失联]
			'''
	}

	XiaoZhiTiaoRE: {
		DisplayName: 启示录-前篇
		Tooltip:
			'''
			[c/494949:“钢铁的终点是毁灭，但在毁灭中诞生真知。]
			[c/494949:现在，抛下那两份极黑色的，不属于你的旧力，让世界重新赋予你启示。”]
			'''
	}

	KaiJuXiaoZhiTiao: {
		DisplayName: 一张说明书？
		Tooltip:
			'''
			本模组内含所有原灾长枪的投掷版本
			请前往设置》控制按键》配置自定义按键》更改长枪形态
			手持戳刺长枪按下切换键可以切换至对应版本的投掷长枪，反之亦然
			'''
		ShiftTip: 按住左Shift键查看更多详细信息
		ShiftTipDetailed:
			'''
			感谢以下人员对mod作出的贡献【排名不分先后】
			南鸢北笙、锯角、VectorChaos、终末犽戎、家庭电脑、沐雪凝春Yukimu、终子星Endticle Star
			'''
	}

