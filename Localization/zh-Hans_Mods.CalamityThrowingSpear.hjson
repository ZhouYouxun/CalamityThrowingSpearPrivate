ChangedWeapons: {
	APreHardMode: {
		AmidiasTridentJav: {
			DisplayName: 海王三叉戟
			Tooltip:
				'''
				扔出直线飞行且无限穿透的三叉戟
				三叉戟爆炸时会释放几个水龙卷，旋转一段时间后追踪敌人
				[c/5276fc:“皆若空游无所依”]
				'''
		}

		GoldplumeJav: {
			DisplayName: 金羽
			Tooltip:
				'''
				向上坠落
				在空中不断地往敌人处发射羽毛弹幕
				[c/52f2fc:“下就是上”]
				'''
		}

		SausageMakerJav: {
			DisplayName: 香肠矛
			Tooltip:
				'''
				可以穿透多次
				消失时释放追踪血弹
				[c/a21c12:“好次”]
				'''
		}

		YateveoBloomJav: {
			DisplayName: 绽花毒藤
			Tooltip:
				'''
				在方块上反弹，使敌人中毒
				消失时释放叶子
				[c/34a212:“赠人玫瑰，手有余猩”]
				'''
		}
	}

	BPrePlantera: {
		BrimlanceJav: {
			DisplayName: 硫磺火矛
			Tooltip:
				'''
				击中一个敌人后弹向最近的敌人
				在第2次击中时释放硫磺火焰
				[c/a21512:“为什么它会弹射”]
				'''
		}

		EarthenJav: {
			DisplayName: 磐石地元叉
			Tooltip:
				'''
				可反弹多次
				反弹时炸出大量岩石碎片
				[c/ac8f50:“别敲了，地板都被你敲碎了”]
				'''
		}

		StarnightLanceJav: {
			DisplayName: 星夜长枪
			Tooltip:
				'''
				本体追踪
				消失时释放追踪转向的星夜光束
				[c/f692ff:“能不能多释放一道剑气”]
				'''
		}
	}

	CPreMoodLord: {
		AstralPikeJav: {
			DisplayName: 幻星矛
			Tooltip:
				'''
				掷出一柄高速投矛
				击中敌人时，投矛会产生星爆并在远端召唤幻星
				如果撞击物块，那么投矛会穿墙并追踪敌人
				[c/ffbf73:“钻地流星”]
				'''
		}

		BotanicPiercerJav: {
			DisplayName: 翠芒尖枪
			Tooltip:
				'''
				飞行很短的时间后快速分裂成两发追踪植物能量束
				分裂前投矛本体具备无限穿透的能力并且会造成150%伤害
				[c/8dff73:“没有人质疑万物生长”]
				'''
		}

		DiseasedJav: {
			DisplayName: 瘟疫长枪
			Tooltip:
				'''
				具备追踪能力并在消失时释放多个追踪的瘟疫弹
				攻击到敌人时会被弹开
				[c/49ff1f:“它飞走了，再也没有回来”]
				'''
		}

		GalvanizingGlaiveJav: {
			DisplayName: 磁能分割刀
			Tooltip:
				'''
				击中敌人时释放多个能量弹
				或者原地旋转的磁能漩涡
				[c/1ffbff:“左零右火，雷公助我”]
				'''
		}

		HellionFlowerJav: {
			DisplayName: 刺花长矛
			Tooltip:
				'''
				命中时释放往正前方延伸的藤蔓与毒云
				藤蔓无限穿透
				[c/007708:“它蔓延了”]
				'''
		}

		TenebreusTidesJav: {
			DisplayName: 深渊潮涌
			Tooltip:
				'''
				投矛飞行期间往两边不断的发射小型三叉戟
				命中敌人也会生成小型三叉戟
				可以穿透很多次
				[c/001087:“它在呼唤你”]
				'''
		}

		TyphonsGreedJav: {
			DisplayName: 提丰之贪婪
			Tooltip:
				'''
				撞墙后反弹
				飞行一段时间后自身开始旋转
				旋转模式期间不断的向外释放可以追踪的水弹
				[c/2f366b:“总算有点用了”]
				'''
		}

		VulcaniteLanceJav: {
			DisplayName: 火山之矛
			Tooltip:
				'''
				命中后产生爆炸
				有概率从玩家处释放一个追踪的火焰精灵
				[c/ff8400:“岩浆溢流”]
				'''
		}
	}

	DPreDog: {
		BansheeHookJav: {
			DisplayName: 女妖之爪
			Tooltip:
				'''
				直线飞行，撞到敌人后弹开
				随后会重新飞回这个敌人，第2次造成更高伤害
				消失时释放三片镰刀，随后镰刀会开始往玩家处回收
				[c/ffbcd5:“可回收物”]
				'''
		}

		ElementalLanceJav: {
			DisplayName: 元素长枪
			Tooltip:
				'''
				按顺序射出五种能量投枪
				日曜长枪能够无限穿透并爆炸
				星漩长枪能够释放追踪导弹
				星云长枪击中一次后获得追踪能力
				星尘长枪制造额外的星尘弹幕
				冥思长枪在原地留下熵变爆炸
				[c/8e8e8e:“最应该出现的白矮星却没有到场”]
				'''
		}

		GildedProboscisJav: {
			DisplayName: 镀金鸟喙
			GFBName: 癫痫屮
			Tooltip:
				'''
				击中敌人时能够在玩家周围产生一只癫狂龙裔
				癫狂龙裔最多存在21只，如数量为满则提升长枪本体伤害
				每一只的伤害会随着总数量的提升而变多
				点击右键将它们全部发射出去
				即使切换武器也不会导致癫狂龙裔消失
				[c/ffc71d:“爱鸟人士表示强烈谴责”]
				'''
		}
	}

	EAfterDog: {
		DragonRageJav: {
			DisplayName: 巨龙之怒
			Tooltip:
				'''
				扔出在空中不断旋转的巨龙之怒
				射程有限但无限穿透
				消失时释放多个追踪火焰弹
				[c/ffc27a:“金源巨龙最后的怒火”]
				'''
		}

		NadirJav: {
			DisplayName: 天底
			Tooltip:
				'''
				击中后在原地释放深渊触手，无视无敌帧
				同时释放多个追踪的深渊精华，无视无敌帧
				手持天底时移速越低，伤害增幅越高
				在静止时提供35%的伤害增幅
				[c/867891:“上下相应”]
				'''
		}

		ScourgeoftheCosmosJav: {
			DisplayName: 灾劫宙怨
			Tooltip:
				'''
				击中敌人时给自己回血
				在原地释放爆炸以及追踪的小吞噬者
				[c/9d5ad0:“宇宙的复仇”]
				'''
		}

		StreamGougeJav: {
			DisplayName: 宇宙暗流
			Tooltip:
				'''
				飞行一段时间后，在原地制造多个传送门，能够伤害敌人
				本体在分裂之前可以无限穿透，在分裂之后只能穿透一次
				随后往前方射出多发具备追踪能力的小型复制体，本体不会因此而消失
				[c/9d5ad0:“传送门的背后，是什么呢”]
				'''
		}

		ViolenceJav: {
			DisplayName: 恣睢
			Tooltip:
				'''
				每次击中敌人都会从玩家处释放多个追踪硫火弹
				默认释放3发，场上每存活一个敌方Boss单位便会增加一发
				蠕虫类Boss仅算一个
				[c/a50101:“溜撒点，一起上罢！”]
				'''
		}
	}
}

