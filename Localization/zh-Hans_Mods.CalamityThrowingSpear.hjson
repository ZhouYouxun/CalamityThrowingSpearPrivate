				'''
		}

		SHPCK: {
			DisplayName: SHPCK
			TooltipNormal:
				'''
				左键释放逐渐减速的超热等离子切割刀
				缓慢在空中停下，并释放等离子爆炸
				右键在敌怪体内生成一杆朝着自身快速回收的全息超热等离子切割刀
				[c/99b3ff:“另一维度的传奇”]
				'''
			Tooltip: "[GFB]"
			TooltipGFB: 传奇归来，现在
		}

		SunEssenceJav: {
			DisplayName: 光耀日
			Tooltip:
				'''
				击中敌人后在原地高速旋转并尝试跟上这个敌人
				旋转期间从上空召唤许多天龙之羽
				[c/fffaa3:“超音速羽毛 如何呢？”]
				'''
		}

		TheLastLance: {
			DisplayName: 最后的骑枪
			Tooltip:
				'''
				左键丢出骑枪，命中时释放多道水流
				自身造成冰河时代与霜冻
				右键在短暂的旋转过后，向鼠标位置发动冲刺
				背包里有该武器时若受到致命伤害则会抽出这把枪并执行无限冲刺
				冲刺期间造成极高的毁灭性伤害
				在海洋群系中造成更高伤害
				无限冲刺可通过接触液体的方式来手动停下
				[c/0024ff:“现在你是——命运的宠儿”]
				'''
		}
	}

	CPreMoodLord: {
		FestiveHalberd: {
			DisplayName: 节日长戟
			Tooltip:
				'''
				在路径上不断的往上喷出大量的圣诞彩灯
				命中时释放一颗追踪别人的五角星，并往上喷射出针刺
				[c/86ff4b:“因为你发觉了地心引力”]
				'''
		}

		Sagittarius: {
			DisplayName: 贯星枪-人马座
			Tooltip:
				'''
				扔出高速的贯星枪
				连续命中5次即可释放一个逐渐蓄力的充能贯星枪
				充能贯星枪击中后造成极高伤害并召唤大量追踪小型贯星枪
				击中敌人时释放施加减益
				耀光在白天降低敌人30%的攻击力，在晚上降低敌人50%的防御力
				[c/fff94b:“贯穿星辰”]
				'''
		}

		TidalMechanics: {
			DisplayName: 潮汐
			Tooltip:
				'''
				逐渐减速并快速飞向距离自己最近的敌人
				弹幕消失时在原地释放两个公转的无限穿透的台风
				右键给自己套上一个泡泡，阻挡1次弹幕伤害后消失
				随后进入30秒的冷却，右键可提早取消泡泡
				手持该武器时，玩家背包里每有5个水元素的战士武器
				便会给玩家提升75%的战士伤害与10点战士暴击率
				[c/689bf4:“这一击，我为你挡下”]
				'''
		}

		Surfeiter: {
			Tooltip:
				'''
				手持时在头顶生成一个鼓
				左键扔出一根长枪，命中时在两侧分别生成一堵石墙碾压中间的敌人
				在击中鼓时会产生对应的音波与火焰
				音波会对敌人施加对应的减益，火焰会在一定时间的延迟后再次产生音波
				笞：受到的伤害x1.03
				杖：接触伤害降低30%
				徒：降低40点防御
				流：移动速度减半
				死：每隔两秒受到5000点固定伤害
				右键切换鼓的类型
				[c/B8860B:“生犯贪嗔痴戾疑，死受鞭笞釜灼烹”]
				'''
			DisplayName: 巴蛇吞象
		}
	}

